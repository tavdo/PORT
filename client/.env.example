# Copy to Vercel: Project → Settings → Environment Variables (Production / Preview).
# Public URL of your Express API (must include /api). Example after you host the API on Railway/Render/etc.
NEXT_PUBLIC_API_URL=https://your-backend.example.com/api

# Optional — match server defaults if omitted
NEXT_PUBLIC_DEFAULT_PORT_STAY_HOURS=120
NEXT_PUBLIC_DEFAULT_USD_TO_GEL=2.7
