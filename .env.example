PORT=3000
NODE_ENV=development

# Default FX when captain sends only IMO
DEFAULT_USD_TO_GEL=2.7
# Default port stay (hours) when omitted
DEFAULT_PORT_STAY_HOURS=120

# Ship API — VesselAPI (https://vesselapi.com): set SHIP_API_KEY only; URL defaults to IMO static lookup.
# Or set SHIP_API_URL to any template with {imo}, e.g. https://api.vesselapi.com/v1/vessel/{imo}?filter.idType=imo
SHIP_API_URL=
SHIP_API_KEY=
SHIP_API_TIMEOUT_MS=8000

# Cache TTL for ship data (seconds)
SHIP_CACHE_TTL_SECONDS=3600

# SQLite DB (requests, users, pricing overrides, audit)
DATABASE_PATH=

# Auth — set JWT_SECRET in production
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Bootstrap first admin when database has no admin (optional)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Pricing — all amounts in USD unless noted
PRICING_TONNAGE_PER_GRT=1
PRICING_BERTH=4500
PRICING_TOWAGE_IN=9600
PRICING_TOWAGE_OUT=9600
PRICING_MOORING_IN=480
PRICING_MOORING_OUT=480
PRICING_SANITARY=300
PRICING_WATCHMAN=2100
PRICING_POSITION_INTERNET=2400
PRICING_MONITORING=1500
PRICING_LIGHT_DUES=2700
PRICING_PILOTAGE_IN=300
PRICING_PILOTAGE_OUT=300
PRICING_AGENCY_FEE=196.3
PRICING_CLEARANCE=550
PRICING_POLLUTION_RATE_PER_GRT=0.02
